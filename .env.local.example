# Supabase connection (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (server-side only, never exposed to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Personize SDK (server-side only)
PERSONIZE_SECRET_KEY=
PERSONIZE_CONTACTS_COLLECTION_ID=8ef5a304-05b0-4f06-9660-fb948b9fa5d9
PERSONIZE_COMPANIES_COLLECTION_ID=855353ac-4919-4b8e-89f5-f985f45d6ca1
PERSONIZE_MEMORY_COLLECTION_ID=6033bc36-7722-4b56-b71b-b62d1d46c74c

# Anthropic API (server-side only)
ANTHROPIC_API_KEY=

# API route authentication
API_SECRET=
