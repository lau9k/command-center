# Supabase connection (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (server-side only, never exposed to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Personize SDK (server-side only)
PERSONIZE_SECRET_KEY=
PERSONIZE_CONTACTS_COLLECTION_ID=5686312a-7ab7-4cef-897c-576bfeb92aec
PERSONIZE_COMPANIES_COLLECTION_ID=855353ac-4919-4b8e-89f5-f985f45d6ca1
PERSONIZE_MEMORY_COLLECTION_ID=6033bc36-7722-4b56-b71b-b62d1d46c74c

# Anthropic API (server-side only)
ANTHROPIC_API_KEY=

# API route authentication
API_SECRET=

# GitHub API (server-side only — used for repo metrics)
GITHUB_TOKEN=

# Late.so API (server-side only — used for content publishing)
LATE_SO_API_KEY=
