# =============================================================================
# Supabase
# =============================================================================

# Supabase project URL (public, used client-side and server-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous/public key (public, used client-side and server-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-side only, full access — keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase URL used by the MCP Supabase package (packages/mcp-supabase/)
SUPABASE_URL=https://your-project.supabase.co

# =============================================================================
# Personize SDK
# =============================================================================

# Personize secret key for SDK client authentication
PERSONIZE_SECRET_KEY=your-personize-secret-key

# Personize API key for the import endpoint
PERSONIZE_API_KEY=your-personize-api-key

# Personize collection IDs
PERSONIZE_CONTACTS_COLLECTION_ID=your-contacts-collection-id
PERSONIZE_COMPANIES_COLLECTION_ID=your-companies-collection-id
PERSONIZE_MEMORY_COLLECTION_ID=your-memory-collection-id

# =============================================================================
# Anthropic
# =============================================================================

# Anthropic API key for AI-powered features (e.g. contact enrichment)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# =============================================================================
# Plaid (banking integration)
# =============================================================================

# Plaid client ID
PLAID_CLIENT_ID=your-plaid-client-id

# Plaid secret key
PLAID_SECRET=your-plaid-secret

# Plaid environment: sandbox | development | production
PLAID_ENV=sandbox

# 32-byte hex encryption key for Plaid access token encryption
PLAID_ENCRYPTION_KEY=your-64-char-hex-key

# Comma-separated ISO 3166-1 alpha-2 country codes (default: CA)
PLAID_COUNTRY_CODES=CA

# Comma-separated Plaid products to request (default: auth,transactions)
PLAID_PRODUCTS=auth,transactions

# =============================================================================
# GitHub
# =============================================================================

# GitHub personal access token for GitHub API integration
GITHUB_TOKEN=ghp_your-token

# =============================================================================
# Telegram
# =============================================================================

# Telegram bot token for the webhook-based bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Meek community bot token and chat ID for community notifications
MEEK_COMMUNITY_BOT_TOKEN=your-community-bot-token
MEEK_COMMUNITY_CHAT_ID=your-community-chat-id

# =============================================================================
# Sentry (error monitoring)
# =============================================================================

# Sentry DSN for server-side / edge error reporting
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# Sentry DSN for client-side error reporting
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# Sentry organization slug (used during build for source maps)
SENTRY_ORG=your-sentry-org

# Sentry project slug (used during build for source maps)
SENTRY_PROJECT=your-sentry-project

# Sentry auth token (used during build for source map uploads)
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# =============================================================================
# API Security
# =============================================================================

# Shared secret for authenticating internal API routes (e.g. memorize, sync-stats)
API_SECRET=your-api-secret

# Secret key for authenticating cron-triggered API routes (e.g. Plaid sync)
CRON_KEY=your-cron-key

# =============================================================================
# Meek Telegram Bot (meek-telegram-bot/)
# =============================================================================

# Comma-separated Telegram user IDs allowed to run admin commands
ADMIN_USER_IDS=123456789

# CoinGecko coin ID for /price command (default: meek)
COINGECKO_COIN_ID=meek

# URLs displayed by bot info commands
MEEK_WEBSITE_URL=https://example.com
MEEK_TWITTER_URL=https://twitter.com/example
MEEK_TELEGRAM_URL=https://t.me/example

# Comma-separated Telegram user IDs allowed to pin messages
APPROVED_PINNERS=123456789
