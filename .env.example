# =============================================================================
# Supabase
# =============================================================================

# REQUIRED — Supabase project URL (public, used client-side and server-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# REQUIRED — Supabase anonymous/public key (public, used client-side and server-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# REQUIRED — Supabase service role key (server-side only, full access — keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OPTIONAL — Supabase URL used by the MCP Supabase package (packages/mcp-supabase/)
SUPABASE_URL=https://your-project.supabase.co

# =============================================================================
# Personize SDK
# =============================================================================

# OPTIONAL — Personize secret key for SDK client authentication
PERSONIZE_SECRET_KEY=your-personize-secret-key

# OPTIONAL — Personize API key for the import endpoint
PERSONIZE_API_KEY=your-personize-api-key

# OPTIONAL — Personize collection IDs
PERSONIZE_CONTACTS_COLLECTION_ID=your-contacts-collection-id
PERSONIZE_COMPANIES_COLLECTION_ID=your-companies-collection-id
PERSONIZE_MEMORY_COLLECTION_ID=your-memory-collection-id

# =============================================================================
# Anthropic
# =============================================================================

# OPTIONAL — Anthropic API key for AI-powered features (e.g. contact enrichment)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# =============================================================================
# Gmail OAuth (email integration)
# =============================================================================

# OPTIONAL — Google OAuth client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id

# OPTIONAL — Google OAuth client secret (from Google Cloud Console)
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OPTIONAL — 32-byte hex encryption key for Gmail refresh token encryption
GMAIL_ENCRYPTION_KEY=your-64-char-hex-key

# =============================================================================
# Plaid (banking integration)
# =============================================================================

# OPTIONAL — Plaid client ID
PLAID_CLIENT_ID=your-plaid-client-id

# OPTIONAL — Plaid secret key
PLAID_SECRET=your-plaid-secret

# OPTIONAL — Plaid environment: sandbox | development | production
PLAID_ENV=sandbox

# OPTIONAL — 32-byte hex encryption key for Plaid access token encryption
PLAID_ENCRYPTION_KEY=your-64-char-hex-key

# PREVIEW_ONLY — Comma-separated ISO 3166-1 alpha-2 country codes (default: CA)
PLAID_COUNTRY_CODES=CA

# PREVIEW_ONLY — Comma-separated Plaid products to request (default: auth,transactions)
PLAID_PRODUCTS=auth,transactions

# =============================================================================
# GitHub
# =============================================================================

# OPTIONAL — GitHub personal access token for GitHub API integration
GITHUB_TOKEN=ghp_your-token

# =============================================================================
# Telegram
# =============================================================================

# OPTIONAL — Telegram bot token for the webhook-based bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# OPTIONAL — Meek community bot token and chat ID for community notifications
MEEK_COMMUNITY_BOT_TOKEN=your-community-bot-token
MEEK_COMMUNITY_CHAT_ID=your-community-chat-id

# =============================================================================
# Sentry (error monitoring)
# =============================================================================

# PRODUCTION_ONLY — Sentry DSN for server-side / edge error reporting
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# PRODUCTION_ONLY — Sentry DSN for client-side error reporting
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0

# OPTIONAL — Sentry organization slug (used during build for source maps)
SENTRY_ORG=your-sentry-org

# OPTIONAL — Sentry project slug (used during build for source maps)
SENTRY_PROJECT=your-sentry-project

# OPTIONAL — Sentry auth token (used during build for source map uploads)
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# =============================================================================
# API Security
# =============================================================================

# REQUIRED — Shared secret for authenticating internal API routes (e.g. memorize, sync-stats)
API_SECRET=your-api-secret

# REQUIRED — Secret key for authenticating cron-triggered API routes (e.g. Plaid sync)
CRON_KEY=your-cron-key

# =============================================================================
# Upstash Redis (rate limiting)
# =============================================================================

# OPTIONAL — Upstash Redis REST URL for distributed rate limiting (falls back to in-memory)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# OPTIONAL — Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# =============================================================================
# Meek Telegram Bot (meek-telegram-bot/)
# =============================================================================

# OPTIONAL — Comma-separated Telegram user IDs allowed to run admin commands
ADMIN_USER_IDS=123456789

# PREVIEW_ONLY — CoinGecko coin ID for /price command (default: meek)
COINGECKO_COIN_ID=meek

# PREVIEW_ONLY — URLs displayed by bot info commands
MEEK_WEBSITE_URL=https://example.com
MEEK_TWITTER_URL=https://twitter.com/example
MEEK_TELEGRAM_URL=https://t.me/example

# OPTIONAL — Comma-separated Telegram user IDs allowed to pin messages
APPROVED_PINNERS=123456789
