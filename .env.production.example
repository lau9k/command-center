# =============================================================================
# Vercel Environment Variables
# =============================================================================
# Set these in the Vercel dashboard under Settings > Environment Variables.
# All three are required for the app to function.
#
# NEXT_PUBLIC_* vars are exposed to the browser. SUPABASE_SERVICE_ROLE_KEY
# is server-only and must NEVER be prefixed with NEXT_PUBLIC_.
# =============================================================================

# Supabase connection (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (server-side only, never exposed to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Personize SDK (server-side only)
PERSONIZE_SECRET_KEY=
PERSONIZE_CONTACTS_COLLECTION_ID=8ef5a304-05b0-4f06-9660-fb948b9fa5d9
PERSONIZE_COMPANIES_COLLECTION_ID=855353ac-4919-4b8e-89f5-f985f45d6ca1
PERSONIZE_MEMORY_COLLECTION_ID=6033bc36-7722-4b56-b71b-b62d1d46c74c

# Anthropic API (server-side only)
ANTHROPIC_API_KEY=

# API route authentication
API_SECRET=

# =============================================================================
# Supabase Auth Configuration (set in Supabase dashboard, not here)
# =============================================================================
# In your Supabase project under Authentication > URL Configuration:
#
# Site URL:
#   https://your-vercel-domain.vercel.app
#
# Redirect URLs (add all of these):
#   http://localhost:3000/callback
#   https://your-vercel-domain.vercel.app/callback
#   https://*-your-vercel-team.vercel.app/callback
#
# The wildcard pattern allows Vercel preview deployments to work with auth.
# =============================================================================
